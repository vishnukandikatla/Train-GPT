# TrainGPT AI Environment Variables — COPY THIS FILE TO .env AND FILL IN YOUR VALUES
# DO NOT commit your actual .env file to git

# Google Gemini API Key — get from https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# RapidAPI Key for Railway APIs — get from https://rapidapi.com/
# Required plan: Basic or higher on the IRCTC API
RAILWAY_API_KEY=your_rapidapi_key_here

# MongoDB Connection URI — defaults to localhost, or use MongoDB Atlas
MONGODB_URI=mongodb://localhost:27017/traingpt

# FastAPI Server Settings
HOST=0.0.0.0
PORT=8000

# Live Railway API Hosts (RapidAPI)
RAILWAY_SEARCH_HOST=irctc1.p.rapidapi.com
RAILWAY_PNR_HOST=irctc-indian-railway-pnr-status.p.rapidapi.com
RAILWAY_AVAILABILITY_HOST=indian-railway-seat-availability.p.rapidapi.com
RAILWAY_RUNNING_HOST=train-running-api.p.rapidapi.com
